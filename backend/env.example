# Copy to `.env` in this folder. Do not commit `.env`.

# Auth0: same tenant as the Next.js app. AUTH0_AUDIENCE must match the API Identifier
# (Dashboard → Applications → APIs → your API → Identifier), e.g. https://yhack-hotbills
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://yhack-hotbills

# Supabase: Project Settings → API (URL + service_role key).
SUPABASE_URL=
SUPABASE_KEY=

# Supabase: Project Settings → Database → Connection string (URI).
# Prefer "Session" or "Transaction" pooler mode when the dashboard recommends it for your stack.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/postgres

# LegiScan API (existing feature)
LEGISCAN_API_KEY=

# Optional: comma-separated browser origins allowed to call /api/* (defaults to Next.js dev URLs)
# CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
